name: 🎬 Viral Shorts Machine

on:
  schedule:
    - cron: "0 4,10,16,22 * * *"
  workflow_dispatch:

jobs:
  generate-and-upload:
    runs-on: ubuntu-latest
    timeout-minutes: 30

    steps:
      - name: ⬇️ Checkout repo
        uses: actions/checkout@v4

      - name: 🐍 Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"
          cache: pip

      - name: 📦 Install dependencies
        run: pip install -r requirements.txt

      - name: 🚀 Run Viral Shorts Machine
        env:
          GROQ_API_KEY:             ${{ secrets.GROQ_API_KEY }}
          DEEPGRAM_API_KEY:         ${{ secrets.DEEPGRAM_API_KEY }}
          PEXELS_API_KEY:           ${{ secrets.PEXELS_API_KEY }}
          PIXABAY_API_KEY:          ${{ secrets.PIXABAY_API_KEY }}
          CREATOMATE_API_KEY:       ${{ secrets.CREATOMATE_API_KEY }}
          YT_CLIENT_ID:             ${{ secrets.YT_CLIENT_ID }}
          YT_CLIENT_SECRET:         ${{ secrets.YT_CLIENT_SECRET }}
          YT_REFRESH_TOKEN:         ${{ secrets.YT_REFRESH_TOKEN }}
          YOUTUBE_PLAYLIST_ID:      ${{ secrets.YOUTUBE_PLAYLIST_ID }}
          GOOGLE_CREDENTIALS_JSON:  ${{ secrets.GOOGLE_CREDENTIALS_JSON }}
          SHEETS_DOC_ID:            ${{ secrets.SHEETS_DOC_ID }}
        run: python main-2\ \(1\).py
